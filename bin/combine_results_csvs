#!/usr/bin/env -S uv run python
import argparse
import csv
import re
from pathlib import Path


HEADERS = [
    "input_filename",
    "run_number",
    "log10_scale_diff",
    "interior_area_iou",
    "log10_unscaled_area_diff",
    "log10_area_diff",
]

RUN_RE = re.compile(r"_run_(\d+)\.csv$")


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser()
    parser.add_argument("--input-images-dir", type=Path, default=Path("input_images"))
    parser.add_argument("output_csv", type=Path)
    parser.add_argument("input_csvs", nargs="+", type=Path)
    return parser.parse_args()


def input_filenames(input_images_dir: Path) -> list[str]:
    paths = sorted(input_images_dir.glob("*.webp"))
    if not paths:
        raise ValueError(f"no .webp files found in {input_images_dir}")
    return [path.stem for path in paths]


def run_number(path: Path) -> int:
    match = RUN_RE.search(path.name)
    if match is None:
        raise ValueError(f"could not parse run number from {path}")
    return int(match.group(1))


def format_float(value: float) -> str:
    return format(value, ".12g")


def read_results(path: Path, names: list[str]) -> list[list[str]]:
    rows = []
    number = run_number(path)
    with path.open(newline="") as file:
        for line_number, row in enumerate(csv.reader(file), start=1):
            if len(row) != 3:
                raise ValueError(f"{path}:{line_number}: expected 3 columns, got {len(row)}")
            if len(rows) >= len(names):
                raise ValueError(f"{path}: expected {len(names)} rows, got more")
            log10_scale_diff = float(row[0])
            log10_area_diff = float(row[2])
            log10_unscaled_area_diff = log10_area_diff - 2 * log10_scale_diff
            rows.append(
                [
                    names[len(rows)],
                    str(number),
                    row[0],
                    row[1],
                    format_float(log10_unscaled_area_diff),
                    row[2],
                ]
            )
    if len(rows) != len(names):
        raise ValueError(f"{path}: expected {len(names)} rows, got {len(rows)}")
    return rows


def main() -> None:
    args = parse_args()
    names = input_filenames(args.input_images_dir)
    input_csvs = sorted(args.input_csvs, key=run_number)
    args.output_csv.parent.mkdir(parents=True, exist_ok=True)

    with args.output_csv.open("w", newline="") as file:
        writer = csv.writer(file, lineterminator="\n")
        writer.writerow(HEADERS)
        for path in input_csvs:
            writer.writerows(read_results(path, names))


if __name__ == "__main__":
    main()
